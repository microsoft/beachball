{
  "name": "beachball",
  "version": "2.64.2",
  "description": "The Sunniest Semantic Version Bumper",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/beachball"
  },
  "homepage": "https://microsoft.github.io/beachball/",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": "./bin/beachball.js",
  "engines": {
    "node": ">=22.18.0"
  },
  "files": [
    "bin",
    "lib/!(__*)",
    "lib/!(__*)/**/*"
  ],
  "scripts": {
    "beachball": "node ./lib/cli.js",
    "build": "tsc",
    "bump": "yarn beachball bump",
    "change": "yarn beachball change",
    "checkchange": "yarn beachball check",
    "docs": "echo \"Run this from the docs folder instead\" && exit 1",
    "docs:build": "echo \"Run this from the docs folder instead\" && exit 1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "lint": "yarn lint:deps && yarn lint:marketplace && yarn lint:code",
    "lint:code": "eslint --color --max-warnings=0 src && echo 'eslint succeeded'",
    "lint:deps": "depcheck .",
    "lint:marketplace": "node scripts/lint-marketplace.js",
    "pub": "yarn beachball publish",
    "release": "yarn beachball publish -y",
    "release:docs": "echo \"Run this from the docs folder instead\" && exit 1",
    "test": "jest",
    "test:all": "yarn test:unit && yarn test:func && yarn test:e2e",
    "test:e2e": "jest --selectProjects e2e",
    "test:func": "jest --selectProjects functional",
    "test:unit": "jest --selectProjects unit",
    "test:watch": "jest --watch",
    "update-snapshots": "yarn test:unit -u && yarn test:func -u && yarn test:e2e -u"
  },
  "lint-staged": {
    "*": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@vercel/detect-agent": "^1.2.1",
    "cosmiconfig": "^9.0.1",
    "execa": "^5.1.1",
    "minimatch": "^3.1.5",
    "npm-registry-fetch": "^14.0.0",
    "p-graph": "^1.3.0",
    "p-limit": "^3.1.0",
    "prompts": "^2.4.2",
    "semver": "^7.7.4",
    "workspace-tools": "^0.41.2",
    "yargs-parser": "^21.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/minimatch": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/npm-registry-fetch": "^8.0.9",
    "@types/prompts": "^2.4.2",
    "@types/semver": "^7.3.13",
    "@types/tmp": "^0.2.3",
    "@types/yargs-parser": "^21.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@typescript-eslint/utils": "^5.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-etc": "^2.0.3",
    "get-port": "^5.0.0",
    "husky": "^8.0.0",
    "jest": "^29.0.0",
    "lint-staged": "^12.0.0",
    "normalized-tmpdir": "^1.0.1",
    "prettier": "~2.8.4",
    "strip-ansi": "^6.0.1",
    "tmp": "^0.2.1",
    "ts-jest": "29.2.6",
    "typescript": "~5.2.0",
    "verdaccio": "5.29.2",
    "verdaccio-auth-memory": "10.2.2",
    "verdaccio-memory": "10.3.2"
  },
  "resolutions": {
    "@types/node@npm:*": "^22.0.0",
    "handlebars@4.7.8": "^4.7.9",
    "js-yaml@npm:4.1.0": "^4.1.1",
    "lodash@npm:4.17.21": "^4.18.1",
    "minimatch@npm:7.4.6": "^7.4.9",
    "qs@npm:6.10.4": "^6.15.0",
    "qs@npm:6.11.0": "^6.15.0",
    "validator@npm:13.11.0": "^13.11.0"
  },
  "rationale": {
    "devDependencies": {
      "ts-jest@29.2.6": "29.3.0 introduces type-fest v4 which requires node 16+"
    },
    "resolutions": {
      "handlebars": "unpin due to security issue",
      "js-yaml": "unpin due to security issue",
      "lodash": "unpin due to security issue",
      "minimatch": "unpin due to security issue",
      "qs": "unpin due to security issue",
      "validator": "unpin due to security issue"
    }
  }
}
