{
  "compilerOptions": {
    // compatible with node 22
    "target": "ES2024",
    // Use CJS output for now
    "module": "node20",
    "moduleResolution": "node16",
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "lib": ["ES2024"],
    "types": ["node"]
  }
}
