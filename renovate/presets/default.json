{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "description": "Recommended config which is intended to be appropriate for most projects.",

  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":configMigration",
    "github>microsoft/beachball//renovate/presets/dependencyDashboardMajor",
    "github>microsoft/beachball//renovate/presets/groupReact"
  ],

  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,

  "minimumReleaseAge": "3 days",

  "printConfig": true,

  "configMigration": true,

  "configWarningReuseIssue": false,

  "timezone": "America/Los_Angeles",

  "vulnerabilityAlerts": {
    "enabled": true
  },

  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "commitMessageTopic": "devDependency {{{depName}}}"
    },
    {
      "matchManagers": ["npm"],
      "minimumReleaseAge": "7 days"
    }
  ]
}
