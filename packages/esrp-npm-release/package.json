{
  "name": "@microsoft/esrp-npm-release",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "description": "ESRP npm release helper",
  "bin": "bin/esrp-npm-release.mjs",
  "private": true,
  "exports": {
    ".": null
  },
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "files": [
    "bin",
    "dist",
    "NOTICE.txt"
  ],
  "scripts": {
    "build": "yarn run -T tsc --pretty",
    "bundle": "node ../../scripts/bundleNode.ts",
    "depcheck": "yarn run -T depcheck .",
    "lint": "yarn run -T eslint --color --max-warnings=0 src",
    "start": "node src/index.ts",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' yarn run -T jest"
  },
  "dependencies": {
    "@azure/core-auth": "^1.10.1",
    "@azure/msal-node": "^5.1.5",
    "@azure/storage-blob": "^12.31.0",
    "execa": "^5.1.1",
    "jws": "patch:jws@npm%3A4.0.1#~/.yarn/patches/jws-npm-4.0.1-0d8c257cbe.patch",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@microsoft/beachball-scripts": "workspace:^",
    "@types/jws": "^3.2.11",
    "@types/yazl": "^3.3.1",
    "cross-env": "^10.1.0"
  }
}
