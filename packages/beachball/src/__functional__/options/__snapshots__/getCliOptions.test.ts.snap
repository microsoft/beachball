// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`getCliOptions shows "bump" command help text 1`] = `
"Usage: beachball bump [options]

Bump versions and generate changelogs, but don't commit or publish.

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Options:
  --[no-]bump-deps            bump packages that depend on changed packages (default: true)
  --prerelease-prefix <value> prerelease prefix for packages that will receive a prerelease bump
  --[no-]keep-change-files    don't delete the change files from disk after bumping

Change detection options:
  -b, --branch <value>        target branch from remote (default: the default remote branch)
  --since <value>             consider change files since this git ref (branch name, commit SHA)
  --[no-]fetch                fetch from the remote before determining changes (default: true)
  --depth <num>               for shallow clones: depth of git history to consider when fetching

Package filtering options:
  --scope <value...>          only consider package paths matching the pattern(s) (supports
                                "!negations")

Validation options:
  --disallowed-change-types <value...> - change types that are not allowed (choices: "none",
                                "prerelease", "prepatch", "patch", "preminor", "minor", "premajor",
                                "major")

Advanced options:
  --change-dir <value>        directory name or path to store change files (default: "change")
  --concurrency <num>         maximum concurrency for write operations (hook calls, npm publish,
                                default: 1)

Common options:
  -c, --config <value>        custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose              print additional information to the console
  -h, --help                  display help for command
"
`;

exports[`getCliOptions shows "canary" command help text 1`] = `
"Usage: beachball canary [options]

Publish prerelease versions of changed or all packages without committing.

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Options:
  --canary-name <value>       dist-tag and version name to use for canary publishes

Change detection options:
  -b, --branch <value>        target branch from remote (default: the default remote branch)
  --since <value>             consider change files since this git ref (branch name, commit SHA)
  --[no-]fetch                fetch from the remote before determining changes (default: true)
  --depth <num>               for shallow clones: depth of git history to consider when fetching

Package filtering options:
  --scope <value...>          only consider package paths matching the pattern(s) (supports
                                "!negations")
  --[no-]all                  publish prerelease versions of all packages (default: false)

Validation options:
  --disallowed-change-types <value...> - change types that are not allowed (choices: "none",
                                "prerelease", "prepatch", "patch", "preminor", "minor", "premajor",
                                "major")

npm options:
  -r, --registry <value>      npm registry (respects npm settings)
  -n, --token <value>         npm auth token (prefer using NPM_TOKEN env var or existing npm login)
  -a, --auth-type <value>     npm auth type if manually providing NPM_TOKEN (choices: "authtoken",
                                "password", default: "authtoken")
  --npm-read-concurrency <num> - maximum concurrency for reading package versions from the registry
                                (default: 2)
  --timeout <num>             timeout in ms for npm operations (other than install)
  -t, --tag <value>           npm dist-tag for publishing (default: canaryName or "canary")
  --access <value>            npm publish access level (respects npm settings) (choices: "public",
                                "restricted")
  --retries <num>             number of retries for an npm publish before failing (default: 3)
  --pack-to-path <value>      pack packages to tgz files under this path instead of publishing to
                                npm

Advanced options:
  --change-dir <value>        directory name or path to store change files (default: "change")
  --concurrency <num>         maximum concurrency for write operations (hook calls, npm publish,
                                default: 1)

Common options:
  -c, --config <value>        custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose              print additional information to the console
  -h, --help                  display help for command
"
`;

exports[`getCliOptions shows "change" command help text 1`] = `
"Usage: beachball change [options]

Create change file(s) for this branch if needed. Considers committed and staged changes, but not
unstaged or untracked changes.

By default, an interactive prompt is used to choose the type and message for each changed package.
Use --message and --type (and optionally --package) to skip the prompt. For help choosing a change
type, see https://microsoft.github.io/beachball/concepts/change-types

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Options:
  -m, --message <value>       change description for all changed packages, instead of prompting
  --type <value>              semver change type for all changed packages, instead of prompting
                                (respects disallowedChangeTypes) (choices: "none", "prerelease",
                                "prepatch", "patch", "preminor", "minor", "premajor", "major")
  -p, --package <value...>    force creating change file(s) for the specified package(s), regardless
                                of diffs
  --[no-]commit               commit change files (if false, only stage them, default: true)

Change detection options:
  -b, --branch <value>        target branch from remote (default: the default remote branch)
  --since <value>             consider changes since this git ref (branch name, commit SHA)
  --[no-]fetch                fetch from the remote before determining changes (default: true)
  --depth <num>               for shallow clones: depth of git history to consider when fetching

Package filtering options:
  --scope <value...>          only consider package paths matching the pattern(s) (supports
                                "!negations")
  --[no-]all                  generate change files for all packages (default: false)

Validation options:
  --disallowed-change-types <value...> - change types that are not allowed (choices: "none",
                                "prerelease", "prepatch", "patch", "preminor", "minor", "premajor",
                                "major")
  --[no-]disallow-deleted-change-files - verify that no change files were deleted between head and
                                target branch

Advanced options:
  --change-dir <value>        directory name or path to store change files (default: "change")
  --dependent-change-type <value> - change type to use for dependent packages - should rarely be
                                modified (default: patch) (choices: "none", "prerelease",
                                "prepatch", "patch", "preminor", "minor", "premajor", "major")

Common options:
  -c, --config <value>        custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose              print additional information to the console
  -h, --help                  display help for command
"
`;

exports[`getCliOptions shows "check" command help text 1`] = `
"Usage: beachball check [options]

Check whether change file(s) are needed for this branch. Considers committed and staged changes, but
not unstaged or untracked changes.

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Options:
  --changehint <value>        message shown when a change file is needed but missing (default: "Run
                                \\"beachball change\\" to create a change file")

Change detection options:
  -b, --branch <value>        target branch from remote (default: the default remote branch)
  --since <value>             consider changes since this git ref (branch name, commit SHA)
  --[no-]fetch                fetch from the remote before determining changes (default: true)
  --depth <num>               for shallow clones: depth of git history to consider when fetching

Package filtering options:
  --scope <value...>          only consider package paths matching the pattern(s) (supports
                                "!negations")

Validation options:
  --disallowed-change-types <value...> - change types that are not allowed (choices: "none",
                                "prerelease", "prepatch", "patch", "preminor", "minor", "premajor",
                                "major")
  --[no-]disallow-deleted-change-files - verify that no change files were deleted between head and
                                target branch

Advanced options:
  --change-dir <value>        directory name or path to store change files (default: "change")

Common options:
  -c, --config <value>        custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose              print additional information to the console
  -h, --help                  display help for command
"
`;

exports[`getCliOptions shows "config get" command help text 1`] = `
"Usage: beachball config get [options] <name>

Get the value of a config setting (with any overrides).

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Arguments:
  name                  beachball config setting name

Common options:
  -c, --config <value>  custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose        print additional information to the console
  -h, --help            display help for command
"
`;

exports[`getCliOptions shows "config list" command help text 1`] = `
"Usage: beachball config list [options]

List all config settings (with any overrides).

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Common options:
