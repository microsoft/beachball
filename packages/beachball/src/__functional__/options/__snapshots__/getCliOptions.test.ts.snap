exports[`getCliOptions shows "publish" command help text 1`] = `
"Usage: beachball publish [options]

Bump, publish to npm registry, and push updates back to the target branch.

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Options:
  -m, --message <value>       version bump commit description
  --[no-]bump                 bump versions during publish (default: true)
  --[no-]publish              publish to the npm registry (default: true)
  --[no-]push                 push changes back to the remote git branch (default: true)
  -y, --[no-]yes              skip publish confirmation prompts (default: true in CI, false locally)
  --git-timeout <num>         timeout in ms for git push operations
  --[no-]git-tags             create git tags for each published package version (default: true)

Change detection options:
  -b, --branch <value>        target branch from remote (default: the default remote branch)
  --since <value>             consider change files since this git ref (branch name, commit SHA)
  --[no-]fetch                fetch from the remote before determining changes (default: true)
  --depth <num>               for shallow clones: depth of git history to consider when fetching

Package filtering options:
  --scope <value...>          only consider package paths matching the pattern(s) (supports
                                "!negations")

Validation options:
  --disallowed-change-types <value...> - change types that are not allowed (choices: "none",
                                "prerelease", "prepatch", "patch", "preminor", "minor", "premajor",
                                "major")

Versioning options:
  --[no-]bump-deps            bump packages that depend on changed packages (default: true)
  --prerelease-prefix <value> prerelease prefix for packages that will receive a prerelease bump
  --[no-]keep-change-files    don't delete the change files from disk after bumping

npm options:
  -r, --registry <value>      npm registry (respects npm settings)
  -n, --token <value>         npm auth token (prefer using NPM_TOKEN env var or existing npm login)
  -a, --auth-type <value>     npm auth type if manually providing NPM_TOKEN (choices: "authtoken",
                                "password", default: "authtoken")
  --npm-read-concurrency <num> - maximum concurrency for reading package versions from the registry
                                (default: 2)
  --timeout <num>             timeout in ms for npm operations (other than install)
  -t, --tag <value>           npm dist-tag for publishing (default: defaultNpmTag or "latest")
  --access <value>            npm publish access level (respects npm settings) (choices: "public",
                                "restricted")
  --retries <num>             number of retries for an npm publish before failing (default: 3)
  --pack-to-path <value>      pack packages to tgz files under this path instead of publishing to
                                npm

Advanced options:
  --change-dir <value>        directory name or path to store change files (default: "change")
  --concurrency <num>         maximum concurrency for write operations (hook calls, npm publish,
                                default: 1)

Common options:
  -c, --config <value>        custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose              print additional information to the console
  -h, --help                  display help for command
"
`;

exports[`getCliOptions shows "sync" command help text 1`] = `
"Usage: beachball sync [options]

Synchronize package versions from the registry with local package.json versions.

Most options can also be specified in the beachball config (command line options override the
config). See https://microsoft.github.io/beachball/overview/configuration for more info.

Options:
  --scope <value...>          only consider package paths matching the pattern(s) (supports
                                "!negations")
  --[no-]force                use the version from the registry even if it's older than local

npm options:
  -r, --registry <value>      npm registry (respects npm settings)
  -n, --token <value>         npm auth token (prefer using NPM_TOKEN env var or existing npm login)
  -a, --auth-type <value>     npm auth type if manually providing NPM_TOKEN (choices: "authtoken",
                                "password", default: "authtoken")
  --npm-read-concurrency <num> - maximum concurrency for reading package versions from the registry
                                (default: 2)
  --timeout <num>             timeout in ms for npm operations (other than install)
  -t, --tag <value>           npm dist-tag to sync with (default: defaultNpmTag or "latest")

Common options:
  -c, --config <value>        custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose              print additional information to the console
  -h, --help                  display help for command
"
`;

exports[`getCliOptions shows top-level help text 1`] = `
"Usage: beachball <command> [options]

See https://microsoft.github.io/beachball/ for more documentation.

Commands:
  change                Create change file(s) for this branch if needed
  check                 Check whether change file(s) are needed for this branch
  publish               Bump, publish to npm registry, and push updates back to the target branch
  bump                  Bump versions and generate changelogs, but don't commit or publish
  sync                  Synchronize package versions from the registry with local package.json
                          versions
  config <get|list>     Get or list config settings (requires a sub-command)
  migrate               Help to migrate from beachball v2
  canary                Publish prerelease versions of changed or all packages without committing
  help [command]        display help for command

Common options:
  -c, --config <value>  custom beachball config path (default: cosmiconfig standard paths)
  --[no-]verbose        print additional information to the console
  -v, --version         output the version number
  -h, --help            display help for command
"
`;
